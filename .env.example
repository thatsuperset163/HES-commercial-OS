# Harris Exteriors HQ — copy to .env.local for local use
# Never commit real secrets. On Vercel: Project → Settings → Environment Variables

# App login
APP_PIN=twins6
AUTH_SECRET=change-me-to-a-long-random-string

# Supabase (Project Settings → API in the Supabase dashboard)
# NEXT_PUBLIC_ = safe to expose in the browser (anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# REQUIRED for Sales OS cloud saves (normalized tables / Sales v2).
# Server-only — never prefix with NEXT_PUBLIC_. Without this key the CRM
# falls back to local-only or legacy mode and prospects can disappear.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# After setting keys: run supabase/schema.sql in the Supabase SQL Editor once.
# Redeploy on Vercel after changing env vars.
