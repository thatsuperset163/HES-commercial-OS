# Harris Exteriors HQ — copy to .env.local for local use
# Never commit real secrets. On Vercel: Project → Settings → Environment Variables

# App login
APP_PIN=twins6
AUTH_SECRET=change-me-to-a-long-random-string

# Supabase (Project Settings → API in the Supabase dashboard)
# NEXT_PUBLIC_ = safe to expose in the browser (anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Public marketing site (/site) — shown on Call buttons
# Example: NEXT_PUBLIC_BUSINESS_PHONE=5551234567
NEXT_PUBLIC_BUSINESS_PHONE=

# REQUIRED for durable cloud saves across the whole site:
# - Sales OS (normalized tables / Sales v2)
# - HQ / Personal / Jobs (blackboard_workspace)
# Server-only — never prefix with NEXT_PUBLIC_. Without this key, data can
# fall back to browser-only storage and disappear across devices.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# After setting keys: run supabase/schema.sql in the Supabase SQL Editor once.
# Redeploy on Vercel after changing env vars.
# Trust the live site only when HQ says "Cloud synced" and Sales says
# "Cloud: Sales v2".
